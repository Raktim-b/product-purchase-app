<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <title><%= title %></title>
  </head>

  <body class="bg-gray-100 min-h-screen text-sm font-sans">

<div class="flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200">

        <div class="p-6 ">
            <h2 class="text-2xl font-bold text-blue-600">
                Inventory
            </h2>
        </div>

        <nav class="mt-6 flex flex-col gap-2 px-4">

            <a href="/categories"
               class="text-gray-700 hover:bg-gray-100 px-4 py-3 rounded-lg">
                Categories
            </a>

            <a href="/products"
               class=" bg-blue-500 text-white px-4 py-3 rounded-lg ">
                Products
            </a>

        </nav>

    </aside>

    <!-- Main Content -->
    <main class="flex-1">

        <div class="max-w-350 w-full mx-auto px-6 py-10">
      <!-- HEADER -->
      <div class="flex justify-between items-end mb-6">
        <div>
          <h1 class="text-2xl font-medium text-gray-900"> Products</h1>
          <p class="text-sm text-gray-500 mt-1">
            Manage your inventory — <%= data.length %> products listed
          </p>
        </div>
        <div class="flex gap-2">
         
          <a
            href="/products/add"
            class="inline-flex! items-center gap-1 bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium px-4 py-3 rounded-lg transition"
          >
            Add product
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path
                d="M12 8V16M16 12H8M12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21Z"
                stroke="#fff"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
          <a
            href="/products/trash"
            class="inline-flex! items-center gap-1 bg-amber-400 hover:bg-amber-500 text-amber-900 text-sm font-medium px-4 py-3 rounded-lg transition"
          >
            Trash
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
              <path
                d="M3 3L21 21M18 6L17.6 12M17.2498 17.2527L17.1991 18.0129C17.129 19.065 17.0939 19.5911 16.8667 19.99C16.6666 20.3412 16.3648 20.6235 16.0011 20.7998C15.588 21 15.0607 21 14.0062 21H9.99377C8.93927 21 8.41202 21 7.99889 20.7998C7.63517 20.6235 7.33339 20.3412 7.13332 19.99C6.90607 19.5911 6.871 19.065 6.80086 18.0129L6 6H4M16 6L15.4559 4.36754C15.1837 3.55086 14.4194 3 13.5585 3H10.4416C9.94243 3 9.47576 3.18519 9.11865 3.5M11.6133 6H20M14 14V17M10 10V17"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>
          <a
            href="/products/logout"
            class="inline-flex! items-center gap-1 bg-red-500 hover:bg-red-600 text-white text-sm font-medium px-4 py-3 rounded-lg transition"
          >
            Logout
            <svg
              width="16px"
              height="16px"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                d="M3 3V2H2V3H3ZM12.2929 13.7071C12.6834 14.0976 13.3166 14.0976 13.7071 13.7071C14.0976 13.3166 14.0976 12.6834 13.7071 12.2929L12.2929 13.7071ZM4 11V3H2V11H4ZM3 4H11V2H3V4ZM2.29289 3.70711L12.2929 13.7071L13.7071 12.2929L3.70711 2.29289L2.29289 3.70711Z"
                fill="#fff"
              />
              <path
                d="M4 15V15C4 16.8692 4 17.8038 4.40192 18.5C4.66523 18.9561 5.04394 19.3348 5.5 19.5981C6.19615 20 7.13077 20 9 20H14C16.8284 20 18.2426 20 19.1213 19.1213C20 18.2426 20 16.8284 20 14V9C20 7.13077 20 6.19615 19.5981 5.5C19.3348 5.04394 18.9561 4.66523 18.5 4.40192C17.8038 4 16.8692 4 15 4V4"
                stroke="#fff"
                stroke-width="3"
                stroke-linecap="round"
              />
            </svg>
          </a>
        </div>
      </div>

      
      <!-- TABLE CARD -->
      <div class="bg-white border border-gray-100 rounded-xl overflow-hidden">
        <div
          class="grid grid-cols-9 px-4 py-3 border-b border-gray-100 bg-gray-50"
        >
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            #
          </div>
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            ID
          </div>
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Image
          </div>
          <div
            class="text-xs col-span-2 font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Product
          </div>
         
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Price
          </div>
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Stock
          </div>
         
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Category
          </div>
         
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Actions
          </div>
        </div>

        <!-- GRID ROWS -->
        <div class="divide-y divide-gray-50">
          <% data.forEach((element, index) => { %>

          <div
            class="grid grid-cols-9 items-center px-4 py-3 <%= index % 2 === 0 ? 'bg-white' : 'bg-gray-100' %> transition"
          >
            <!-- SL -->
            <div class="flex justify-center font-mono text-gray-400">
              <%= index + 1 %>
            </div>

            <!-- ID -->
            <div class="flex justify-center font-mono text-gray-400">
              <%= element._id.toString().slice(-4) %>
            </div>
            <!-- Image -->
            <div class="flex justify-center">
              <img
                src="<%= element.image %>"
                class="w-10 h-10 object-cover rounded-md"
              />
            </div>

            <!-- Name -->
            <div
              class="flex col-span-2 justify-center font-medium text-gray-900"
            >
              <%= element.name %>
            </div>

           

            <!-- Price -->
            <div
              class="flex justify-center font-mono font-medium text-gray-800"
            >
              ₹<%= element.price.toLocaleString() %>
            </div>
            <!-- Stock -->
            <div
              class="flex justify-center font-mono font-medium text-gray-800"
            >
              <%= element.stock %>
            </div>

           

            <!-- Category -->
            <div class="flex justify-center">
              <span
                class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-indigo-100 text-indigo-700"
                ><%= element.category.name %></span
              >
            </div>

            <!-- Actions -->
            <div class="flex justify-center items-center gap-2">
              <a
                href="/products/edit/<%= element._id %>"
                class="inline-flex items-center justify-center p-2 rounded-lg bg-blue-100 text-blue-600 border border-blue-100 hover:bg-blue-200 transition"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M20.8477 1.87868C19.6761 0.707109 17.7766 0.707105 16.605 1.87868L2.44744 16.0363C2.02864 16.4551 1.74317 16.9885 1.62702 17.5692L1.03995 20.5046C0.760062 21.904 1.9939 23.1379 3.39334 22.858L6.32868 22.2709C6.90945 22.1548 7.44285 21.8693 7.86165 21.4505L22.0192 7.29289C23.1908 6.12132 23.1908 4.22183 22.0192 3.05025L20.8477 1.87868ZM18.0192 3.29289C18.4098 2.90237 19.0429 2.90237 19.4335 3.29289L20.605 4.46447C20.9956 4.85499 20.9956 5.48815 20.605 5.87868L17.9334 8.55027L15.3477 5.96448L18.0192 3.29289ZM13.9334 7.3787L3.86165 17.4505C3.72205 17.5901 3.6269 17.7679 3.58818 17.9615L3.00111 20.8968L5.93645 20.3097C6.13004 20.271 6.30784 20.1759 6.44744 20.0363L16.5192 9.96448L13.9334 7.3787Z"
                    fill="currentColor"
                  />
                </svg>
              </a>
              <a
                onclick="handleDelete('<%= element._id %>')"
                class="inline-flex items-center justify-center p-2 rounded-lg bg-red-100 text-red-600 border border-red-100 hover:bg-red-200 cursor-pointer"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 6h18" />
                  <path d="M8 6V4h8v2" />
                  <path d="M19 6l-1 14H6L5 6" />
                  <path d="M10 11v6" />
                  <path d="M14 11v6" />
                  <path d="M9 16l3 3 3-3" />
                </svg>
              </a>
            </div>
          </div>

          <% }) %>
        </div>
      </div>
    
    </div>

    <!-- TOAST -->
    <div
      id="toast"
      class="fixed top-16 right-10 z-50 translate-x-full opacity-0 transition-all duration-300 bg-white border-b-2 border-indigo-500 text-gray-600 px-5 flex items-center gap-1 py-4 rounded-md shadow-2xl font-medium"
    >        </div>
    </main>

</div>

<script src="/script/softDeleteScript.js"></script>
<script src="/script/filterMenu.js"></script>
</body>
</html>
