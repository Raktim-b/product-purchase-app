    </div>

  </div>
      <!-- PRODUCT GRID -->
      
      <div id="productGrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

    <% data.forEach((element) => { %>

        <a href="/userPage/products/<%= element._id %>" class="block">

            <div class="overflow-hidden transition duration-300">

                <!-- IMAGE -->
                <div class="h-120 relative overflow-hidden">
                    <img
                        src="<%= element.image %>"
                        alt="<%= element.name %>"
                        class="w-full h-full rounded-lg object-cover hover:scale-105 transition duration-500"
                    />

                    <div class="absolute left-2.5 top-2.5 bg-yellow-300 py-px px-2 rounded-md">
                        <span class="text-gray-700 text-xs uppercase font-semibold">
                            <%= element.category.name %>
                        </span>
                    </div>
                </div>

                <!-- CONTENT -->
                <div class="p-4">
                    <h2 class="font-semibold text-gray-900">
                        <%= element.name %>
                    </h2>

                    <p class="text-sm text-gray-500 mt-2">
                        <%= element.category.name %>
                    </p>

                    <p class="text-lg font-semibold mt-2">
                        ₹<%= element.price.toLocaleString() %>
                    </p>

                    <p class="text-sm text-gray-500">
                        Stock:
                        <span class="text-black font-medium">
                            <%= element.stock %>
                        </span>
                    </p>
                </div>

            </div>

        </a>

    <% }) %>

</div>
        
    </div>
    

    </div>

  </div>
<script>
const socket = io();

let count = 0;

const badge = document.getElementById("notificationCount");
const dropdown = document.getElementById("notificationDropdown");
const button = document.getElementById("notificationBtn");
const productGrid = document.getElementById("productGrid");

const notificationList = document.getElementById("notificationList");
const notificationCountText = document.getElementById("notificationCountText");

socket.on("connect", () => {
    console.log("Socket Connected:", socket.id);
});

socket.on("newProduct", (product) => {

 

    // ==========================
    // Notification Badge
    // ==========================

   count++;

badge.classList.remove("hidden");
badge.innerText = count;

if (count === 1) {
    notificationList.innerHTML = "";
}

// ==========================
// Notification Item
// ==========================

notificationList.insertAdjacentHTML("afterbegin", `
    <div class="p-4 border-b hover:bg-gray-50 transition">

        <p class="font-semibold text-gray-800">
            ${product.name}
        </p>

        <p class="text-sm text-gray-500 mt-1">
            ₹${Number(product.price).toLocaleString()}
        </p>

        <p class="text-xs text-gray-400 mt-1">
            ${product.category}
        </p>

    </div>
`);

    // ==========================
    // Product Card
    // ==========================

    const card = `
        <div class="overflow-hidden transition duration-300">

            <div class="h-120 relative overflow-hidden">

                <img
                    src="${product.image}"
                    class="w-full h-full rounded-lg object-cover hover:scale-105 transition duration-500"
                />

                <div class="absolute left-2.5 top-2.5 bg-yellow-300 py-px px-2 rounded-md">
                    <span class="text-gray-700 text-xs uppercase font-semibold">
                        ${product.category}
                    </span>
                </div>

            </div>

            <div class="p-4">

                <h2 class="font-semibold text-gray-900">
                    ${product.name}
                </h2>

                <p class="text-sm font-medium text-[#8f98a9] mt-3 line-clamp-3">
                    ${product.desc || ""}
                </p>

                <p class="text-lg font-semibold mt-2">
                    ₹${Number(product.price).toLocaleString()}
                </p>

                <p class="text-sm text-gray-500 mt-1">
                    Color:
                    <span class="text-black font-medium">
                        ${
                            Array.isArray(product.color)
                                ? product.color.join(", ")
                                : product.color
                        }
                    </span>
                </p>

                <p class="text-sm text-gray-500 mt-1">
                    Stock:
                    <span class="text-black font-medium">
                        ${product.stock}
                    </span>
                </p>

            </div>

        </div>
    `;

    productGrid.insertAdjacentHTML("afterbegin", card);

});

button.addEventListener("click", (e) => {

    e.stopPropagation();

    dropdown.classList.toggle("hidden");

    count = 0;

    badge.classList.add("hidden");

    badge.innerText = "";

    

});

// Close dropdown when clicking outside
document.addEventListener("click", (e) => {

    if (
        !button.contains(e.target) &&
        !dropdown.contains(e.target)
    ) {
        dropdown.classList.add("hidden");
    }

});
</script>
<script src="/script/filterMenu.js"></script>
</body>
</html>