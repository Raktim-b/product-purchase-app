<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <title><%= title %></title>
  </head>

  <body class="bg-gray-100 min-h-screen text-sm font-sans">
    <div class="max-w-350 w-full mx-auto px-6 py-10">
      <!-- HEADER -->
      <div class="flex justify-between items-end mb-6">
        <div>
          <h1 class="text-2xl font-medium text-gray-900">Trash Products</h1>
          <p class="text-sm text-gray-500 mt-1">
            Deleted items — <%= data.length %> products
          </p>
        </div>

        <div class="flex gap-2">
          <a
            href="/categories"
            class="inline-flex! items-center gap-2 bg-blue-500 hover:bg-blue-600 text-white text-sm font-medium px-4 py-3 rounded-lg transition"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path
                d="M15 18L9 12L15 6"
                stroke="#fff"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>

            Back to Categories
          </a>
        </div>
      </div>

      <!-- TABLE -->
      <div class="bg-white border border-gray-100 rounded-xl overflow-hidden">
        <!-- TABLE HEADER -->
        <div
          class="grid grid-cols-5 px-4 py-3 border-b border-gray-100 bg-gray-50"
        >
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            #
          </div>
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            ID
          </div>
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Image
          </div>
          <div
            class="text-xs  font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Category
          </div>
         
         
          <div
            class="text-xs font-medium text-gray-400 uppercase tracking-wide flex justify-center"
          >
            Actions
          </div>
        </div>

        <!-- TABLE BODY -->
        <div class="divide-y divide-gray-50">
          <% data.forEach((element,index)=>{ %>

          <div
            class="grid grid-cols-5 items-center px-4 py-3 hover:bg-gray-50 transition"
          >
            <!-- SL -->
            <div class="flex justify-center font-mono text-gray-400">
              <%= index+1 %>
            </div>

            <!-- ID -->
            <div class="flex justify-center font-mono text-gray-400">
              <%= element._id.toString().slice(-4) %>
            </div>
            <div class="flex justify-center">
              <img
                src="<%= element.image %>"
                class="w-10 h-10 object-cover rounded-md "
              />
            </div>
            <!-- NAME -->
            <div
              class="flex justify-center font-medium text-gray-900"
            >
              <%= element.name %>
            </div>

            <!-- ACTIONS -->
            <div class="flex justify-center items-center gap-2">
              <!-- RESTORE -->
              <a
                href="/categories/restore/<%= element._id %>"
                class="inline-flex items-center justify-center p-2 rounded-lg bg-green-100 text-green-600 border border-green-100 hover:bg-green-300 transition"
              >
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M3 12H21"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                  <path
                    d="M7 8L3 12L7 16"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                </svg>
              </a>

              <!-- PERMANENT DELETE BUTTON -->
              <button
                onclick="
                  openCategpryDeleteModal('/categories/hardDelete/<%= element._id %>')
                "
                class="inline-flex items-center cursor-pointer justify-center p-2 rounded-lg bg-red-100 text-red-600 border border-red-100 hover:bg-red-200 transition"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none">
                  <path
                    d="M10 12V17"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                  <path
                    d="M14 12V17"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                  />
                  <path d="M4 7H20" stroke="currentColor" stroke-width="2" />
                  <path
                    d="M6 10V18C6 19.6 7.4 21 9 21H15C16.6 21 18 19.6 18 18V10"
                    stroke="currentColor"
                    stroke-width="2"
                  />
                  <path
                    d="M9 5C9 4 10 3 11 3H13C14 3 15 4 15 5V7H9V5Z"
                    stroke="currentColor"
                    stroke-width="2"
                  />
                </svg>
              </button>
            </div>
          </div>

          <% }) %>
        </div>
      </div>
    </div>
    <!-- DELETE MODAL -->
    <div
      id="deleteModal"
      class="fixed inset-0 bg-black/40 hidden items-center justify-center"
    >
      <div class="bg-white rounded-lg shadow-lg p-6 w-80 text-center">
        <h2 class="text-lg font-semibold mb-4 text-gray-800">
          Permanently delete this product?
        </h2>

        <div class="flex justify-center gap-4">
          <!-- CANCEL -->
          <button
            onclick="closeDeleteModal()"
            class="px-4 py-2 rounded-lg bg-gray-200 hover:bg-gray-300"
          >
            Cancel
          </button>

          <!-- DELETE -->
          <a
            id="confirmDeleteBtn"
            href="#"
            class="px-4 py-2 rounded-lg bg-red-600 text-white hover:bg-red-700"
          >
            Delete
          </a>
        </div>
      </div>
    </div>
    <script src="/script/hardDeleteModal.js"></script>
  </body>
</html>
